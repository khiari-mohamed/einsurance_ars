<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<title>Facture Dépôt de Prime PMD — {{affaire.numero}}</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
  :root{--red:#d52b36;--dark:#1a1a2e;--light:#f8f9fa;--border:#dee2e6;--muted:#6c757d;--green:#2d6a4f}
  *{box-sizing:border-box;margin:0;padding:0}
  body{font-family:Arial,Helvetica,sans-serif;font-size:10.5px;color:#212529;background:#fff;line-height:1.4}
  .page-header{background:var(--red);color:#fff;padding:14px 20px;display:flex;justify-content:space-between;align-items:center;border-bottom:4px solid #a51e28}
  .logo-text{font-size:20px;font-weight:700;letter-spacing:1px}
  .logo-sub{font-size:9px;opacity:.85}
  .doc-title{font-size:13px;font-weight:700;letter-spacing:.5px;text-align:center}
  .doc-ref{font-size:9px;opacity:.85;margin-top:3px;text-align:center}
  .parties{display:flex;border-bottom:1px solid var(--border)}
  .party-box{flex:1;padding:12px 16px;border-right:1px solid var(--border)}
  .party-box:last-child{border-right:none}
  .party-label{font-size:8px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.8px;margin-bottom:4px}
  .party-name{font-size:12px;font-weight:700}
  .party-detail{font-size:9px;color:var(--muted);margin-top:2px}
  .section-header{background:var(--light);border-left:4px solid var(--red);padding:6px 12px;font-weight:700;font-size:10px;text-transform:uppercase;letter-spacing:.5px;color:var(--dark)}
  .info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;border-bottom:1px solid var(--border)}
  .info-cell{padding:8px 12px;border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
  .info-cell:nth-child(3n){border-right:none}
  .info-cell .label{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px}
  .info-cell .value{font-weight:600;font-size:10.5px}
  table{width:100%;border-collapse:collapse;font-size:9.5px}
  thead tr{background:var(--red);color:#fff}
  thead th{padding:7px 8px;text-align:right;font-weight:600;font-size:8.5px;text-transform:uppercase;letter-spacing:.3px;border-right:1px solid rgba(255,255,255,.2)}
  thead th:first-child{text-align:left;border-left:none}
  tbody tr:nth-child(even){background:#fafafa}
  tbody td{padding:6px 8px;border-bottom:1px solid var(--border);border-right:1px solid var(--border);text-align:right;vertical-align:middle}
  tbody td:first-child{text-align:left;font-weight:500}
  tfoot tr{background:var(--dark);color:#fff}
  tfoot td{padding:8px;font-weight:700;text-align:right;font-size:10px;border-right:1px solid rgba(255,255,255,.15)}
  tfoot td:first-child{text-align:left}
  .paid-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:8px;font-weight:700;background:#d4edda;color:#155724}
  .pending-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:8px;font-weight:700;background:#fff3cd;color:#856404}
  .overdue-badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:8px;font-weight:700;background:#f8d7da;color:#721c24}
  .summary-bar{display:flex;border-top:2px solid var(--red);border-bottom:2px solid var(--red)}
  .s-cell{flex:1;padding:10px 14px;border-right:1px solid var(--border);text-align:center}
  .s-cell:last-child{border-right:none}
  .s-label{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px}
  .s-value{font-size:13px;font-weight:700;color:var(--red);margin-top:3px}
  .s-currency{font-size:8px;color:var(--muted)}
  .amount-words{background:#fff8f8;border:1px solid #fcc;border-left:4px solid var(--red);padding:10px 14px;margin:10px 0}
  .aw-label{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px}
  .aw-value{font-size:11px;font-weight:700;color:var(--dark);text-transform:uppercase}
  .chart-section{padding:12px 16px;border-top:1px solid var(--border)}
  .chart-title{font-size:9px;font-weight:700;color:var(--red);text-transform:uppercase;letter-spacing:.5px;margin-bottom:8px}
  .signatures{display:flex;border-top:1px solid var(--border);margin-top:16px}
  .sig-block{flex:1;padding:14px 16px;border-right:1px solid var(--border);text-align:center}
  .sig-block:last-child{border-right:none}
  .sig-label{font-size:8px;color:var(--muted);text-transform:uppercase;letter-spacing:.5px;margin-bottom:40px}
  .sig-line{border-top:1px solid var(--border);padding-top:5px;font-size:8px;color:var(--muted)}
  .doc-footer{background:var(--dark);color:rgba(255,255,255,.7);text-align:center;font-size:8px;padding:8px;margin-top:10px}
  @media print{body{-webkit-print-color-adjust:exact;print-color-adjust:exact}}
</style>
</head>
<body>

<div class="page-header">
  <div><div class="logo-text">ARS</div><div class="logo-sub">Réassurance Tunisie</div></div>
  <div>
    <div class="doc-title">FACTURE — DÉPÔT DE PRIME (PMD)</div>
    <div class="doc-ref">Traité {{affaire.numero}} — Émis le {{generatedAt}}</div>
  </div>
  <div style="text-align:right;font-size:9px">
    <div style="opacity:.9">{{company.raisonSociale}}</div>
    <div style="opacity:.7">MF: {{company.matriculeFiscal}}</div>
  </div>
</div>

<div class="parties">
  <div class="party-box">
    <div class="party-label">Courtier</div>
    <div class="party-name">{{company.raisonSociale}}</div>
    <div class="party-detail">{{company.adresse}}</div>
  </div>
  <div class="party-box">
    <div class="party-label">Cédante</div>
    <div class="party-name">{{affaire.cedante.raisonSociale}}</div>
    <div class="party-detail">Compte: {{affaire.cedante.compteComptable}}</div>
  </div>
  <div class="party-box">
    <div class="party-label">Traité</div>
    <div class="party-name">{{affaire.numero}}</div>
    <div class="party-detail">Réf: {{default traite.referenceTraite '—'}}</div>
    <div class="party-detail">{{traite.reassuranceType}} — {{default traite.formeCouverture '—'}}</div>
  </div>
</div>

<div class="section-header">Caractéristiques du Traité</div>
<div class="info-grid">
  <div class="info-cell">
    <div class="label">Date d'effet</div>
    <div class="value">{{formatDate traite.dateEffet}}</div>
  </div>
  <div class="info-cell">
    <div class="label">Date d'échéance</div>
    <div class="value">{{formatDate traite.dateEcheance}}</div>
  </div>
  <div class="info-cell">
    <div class="label">Périodicité PMD</div>
    <div class="value">{{traite.periodicite}}</div>
  </div>
  <div class="info-cell">
    <div class="label">Prime Prévisionnelle</div>
    <div class="value">{{formatNumber (default traite.primePrevisionnelle 0)}} {{affaire.currency}}</div>
  </div>
  <div class="info-cell">
    <div class="label">PMD Total</div>
    <div class="value" style="color:var(--red);font-size:13px">{{formatNumber (default traite.pmd 0)}} {{affaire.currency}}</div>
  </div>
  <div class="info-cell">
    <div class="label">Commission Cédante</div>
    <div class="value">{{formatPercent (default traite.tauxCommissionCedante 0)}}</div>
  </div>
</div>

<div class="section-header" style="margin-top:8px">Calendrier de Versement PMD</div>
<table>
  <thead>
    <tr>
      <th style="text-align:left">Tranche</th>
      <th>Date d'Échéance</th>
      <th>Montant Brut</th>
      <th>Taux Déduction</th>
      <th>Montant Net</th>
      <th>Statut</th>
      <th>Date Paiement</th>
    </tr>
  </thead>
  <tbody>
    {{#each pmdInstalments}}
    <tr>
      <td>Tranche {{numeroTranche}}</td>
      <td style="text-align:right">{{formatDate dateEcheance}}</td>
      <td>{{formatNumber montant}}</td>
      <td>{{formatPercent (default tauxDeduction 0)}}</td>
      <td style="font-weight:700">
        {{formatNumber (subtract montant (multiply montant (divide (default tauxDeduction 0) 100)))}}
      </td>
      <td>
        {{#if isPaid}}
          <span class="paid-badge">Payé</span>
        {{else}}
          {{#ifCond dateEcheance '<' ../now}}
            <span class="overdue-badge">En retard</span>
          {{else}}
            <span class="pending-badge">À payer</span>
          {{/ifCond}}
        {{/if}}
      </td>
      <td style="text-align:right">{{formatDate paidAt}}</td>
    </tr>
    {{/each}}
  </tbody>
  <tfoot>
    <tr>
      <td colspan="2">TOTAL PMD</td>
      <td>{{formatNumber traite.pmd}}</td>
      <td></td>
      <td>{{formatNumber traite.pmd}}</td>
      <td colspan="2"></td>
    </tr>
  </tfoot>
</table>

<div class="summary-bar">
  <div class="s-cell">
    <div class="s-label">PMD Total</div>
    <div class="s-value">{{formatNumber (default traite.pmd 0)}}</div>
    <div class="s-currency">{{affaire.currency}}</div>
  </div>
  <div class="s-cell">
    <div class="s-label">Tranches Payées</div>
    <div class="s-value" style="color:var(--green)">{{paidCount}}</div>
    <div class="s-currency">sur {{totalCount}}</div>
  </div>
  <div class="s-cell">
    <div class="s-label">Montant Payé</div>
    <div class="s-value" style="color:var(--green)">{{formatNumber paidAmount}}</div>
    <div class="s-currency">{{affaire.currency}}</div>
  </div>
  <div class="s-cell">
    <div class="s-label">Solde Restant</div>
    <div class="s-value" style="color:var(--red)">{{formatNumber remainingAmount}}</div>
    <div class="s-currency">{{affaire.currency}}</div>
  </div>
</div>

<div class="amount-words">
  <div class="aw-label">PMD Total en lettres</div>
  <div class="aw-value">{{montantEnLettres}}</div>
</div>

<div class="chart-section">
  <div class="chart-title">Calendrier de Versement PMD — Progression</div>
  <canvas id="pmdChart" height="90"></canvas>
</div>

<div class="signatures">
  <div class="sig-block">
    <div class="sig-label">Pour la Cédante<br>{{affaire.cedante.raisonSociale}}</div>
    <div class="sig-line">Signature et cachet</div>
  </div>
  <div class="sig-block">
    <div class="sig-label">Pour ARS Réassurance</div>
    <div class="sig-line">Signature et cachet</div>
  </div>
  <div class="sig-block">
    <div class="sig-label">Date</div>
    <div class="sig-line">{{generatedAt}}</div>
  </div>
</div>

<div class="doc-footer">
  {{company.raisonSociale}} — Document confidentiel — PMD Traité {{affaire.numero}} — {{generatedAt}}
</div>

<script>
(function() {
  var instalments = {{{json pmdInstalments}}};
  if (!instalments || !instalments.length) {
    window.__chartsReady = true;
    window.dispatchEvent(new Event('chartsReady'));
    return;
  }

  var labels = instalments.map(function(i) { return 'T' + i.numeroTranche; });
  var amounts = instalments.map(function(i) { return Number(i.montant) || 0; });
  var colors  = instalments.map(function(i) {
    return i.isPaid ? '#2d6a4f' : '#d52b36';
  });

  var ctx = document.getElementById('pmdChart');
  if (ctx) {
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: labels,
        datasets: [{
          label: '{{affaire.currency}}',
          data: amounts,
          backgroundColor: colors,
          borderColor: colors,
          borderWidth: 1,
          borderRadius: 3
        }]
      },
      options: {
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: function(c) {
                var isPaid = instalments[c.dataIndex] && instalments[c.dataIndex].isPaid;
                return c.parsed.y.toFixed(3) + ' {{affaire.currency}}' + (isPaid ? ' ✓ Payé' : ' — À payer');
              }
            }
          }
        },
        scales: {
          y: { beginAtZero: true, ticks: { font: { size: 9 } }, grid: { color: '#f0f0f0' } },
          x: { ticks: { font: { size: 9 } }, grid: { display: false } }
        }
      }
    });
  }
  window.__chartsReady = true;
  window.dispatchEvent(new Event('chartsReady'));
})();
</script>
</body>
</html>